+_FAQ_QUESTION_RE = re.compile(r"^\**\s*Q\s*[:.\-]\s*(.+?)\s*\**\s*$", re.IGNORECASE)
+_FAQ_ANSWER_RE = re.compile(r"^\**\s*A\s*[:.\-]\s*(.*)$", re.IGNORECASE)
+_MD_HEADING_RE = re.compile(r"^##\s+\S", re.MULTILINE)
+
