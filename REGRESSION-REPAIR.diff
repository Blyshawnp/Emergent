+        overrides = {}
+
+    fresh_help = (overrides.get("help_markdown") or "").strip()
+    if fresh_help:
+        help_text = fresh_help
+
+    fresh_faq = (overrides.get("faq_markdown") or "").strip()
+    if fresh_faq:
+        faq_text = fresh_faq
+
+    _help_doc_cache["help_markdown"] = help_text
